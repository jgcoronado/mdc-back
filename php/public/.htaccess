DirectoryIndex index.php
Options -MultiViews -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Servir directamente ficheros y directorios reales (portadas /cover/, /assets/…).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Todo lo demás → front controller.
    RewriteRule ^ index.php [L]
</IfModule>

# No servir dotfiles (.htaccess, .git, etc.).
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
