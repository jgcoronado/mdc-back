DirectoryIndex index.php
Options -MultiViews -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Servir directamente ficheros y directorios reales (portadas /cover/, /assets/…).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Todo lo demás → front controller.
    RewriteRule ^ index.php [L]
</IfModule>

# Cabeceras de seguridad.
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Caché larga para estáticos (assets y portadas).
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff2?)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>

# No servir dotfiles (.htaccess, .git, etc.).
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
