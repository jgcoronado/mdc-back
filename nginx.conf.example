server {
    listen 80;
    server_name marchasdecristo.com www.marchasdecristo.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name marchasdecristo.com www.marchasdecristo.com;

    ssl_certificate     /etc/letsencrypt/live/marchasdecristo.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/marchasdecristo.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;

    # Cover images served directly from host volume — no container involved.
    location /cover/ {
        alias /var/www/mdc-assets/cover/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # Everything else goes to Next.js.
    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}
