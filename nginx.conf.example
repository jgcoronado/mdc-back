server {
    listen 80;
    server_name marchasdecristo.com www.marchasdecristo.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name marchasdecristo.com www.marchasdecristo.com;

    # SSL — replace with your cert paths
    ssl_certificate     /etc/letsencrypt/live/marchasdecristo.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/marchasdecristo.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;

    # Cover images served directly from host volume
    location /cover/ {
        alias /var/www/mdc-assets/cover/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # API — routed to Express container
    location /api/ {
        proxy_pass         http://127.0.0.1:8080;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Sitemap — generated by Express (has direct DB access)
    location = /sitemap.xml {
        proxy_pass         http://127.0.0.1:8080;
        proxy_set_header   Host $host;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Admin SPA — served by Express
    location /login {
        proxy_pass         http://127.0.0.1:8080;
        proxy_set_header   Host $host;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    location /dashboard {
        proxy_pass         http://127.0.0.1:8080;
        proxy_set_header   Host $host;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Public site — routed to Next.js container
    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}
