# Copy this file to .env and fill in real values before deploying.
# Never commit .env to git.

# ── Auth / session ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SECRET_KEY=change-me-generate-a-random-48-byte-base64-string

AUTH_COOKIE_NAME=mdc_session

# Session duration in ms (default: 8 h)
LOGIN_TTL_MS=28800000

# Must be true in production (HTTPS required)
COOKIE_SECURE=true

# ── Login brute-force protection ──────────────────────────────
LOGIN_MAX_ATTEMPTS=6
LOGIN_WINDOW_MS=900000
LOGIN_LOCK_MS=900000

# ── Password hashing ──────────────────────────────────────────
PASSWORD_PBKDF2_ITERATIONS=210000
