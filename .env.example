# Copy this file to .env and fill in the values before deploying.

# Auth/session
SECRET_KEY='change-me-use-openssl-rand-base64-48'  # openssl rand -base64 48
AUTH_COOKIE_NAME=mdc_session
LOGIN_TTL_MS=28800000       # session duration: 8 hours
COOKIE_SECURE=true          # set to false only for local HTTP dev

# Login hardening (rate limiting, in-memory per process)
LOGIN_MAX_ATTEMPTS=6
LOGIN_WINDOW_MS=900000      # 15 min window
LOGIN_LOCK_MS=900000        # 15 min lockout
PASSWORD_PBKDF2_ITERATIONS=210000
